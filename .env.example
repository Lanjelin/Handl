PORT=3000
DATA_DIR=./data
DB_FILE=./data/handl.db
PUBLIC_DIR=./public

# Remove inactive lists after this many milliseconds.
PRUNE_AFTER_MS=15552000000

# Debounce writes to SQLite while a list is active.
PERSIST_DEBOUNCE_MS=750

# Force a persistence flush even if activity keeps coming.
PERSIST_MAX_DELAY_MS=30000

# Batch websocket fanout during quick bursts of edits.
BROADCAST_DEBOUNCE_MS=50

# Delay compaction until a list has been idle this long.
COMPACT_IDLE_DELAY_MS=120000

# Send websocket heartbeats so clients can detect stale connections.
HEARTBEAT_MS=3000

# Rolling window used by /metrics for recent request counts.
METRICS_WINDOW_MS=900000

# Restore code generation settings.
SHARE_CODE_LENGTH=8
SHARE_CODE_ALPHABET=ABCDEFGHJKLMNPQRSTUVWXYZ23456789

# Enable lightweight connection timing logs in the browser console.
DEBUG_METRICS=0

# Require a simple password before using the app.
# Leave unset for no login prompt.
PASSWORD=
